{
	"name": "@foilctf/challenge",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "tsc --noEmit",
		"build": "tsc",
		"start": "node --enable-source-maps dist/index.js",
		"dev": "nodemon --enable-source-maps",
		"clean": "rm -rf dist",
		"format": "prettier --write src/ scripts/",
		"schema": "drizzle-kit introspect --config drizzle.config.ts"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^24.10.8",
		"@types/pg": "^8.18.0",
		"drizzle-kit": "^0.31.9",
		"prettier": "3.8.0",
		"ts-node": "^10.9.2",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"cors": "^2.8.6",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.45.1",
		"drizzle-valibot": "^0.4.2",
		"express": "^5.2.1",
		"pg": "^8.17.1",
		"prom-client": "^15.1.3",
		"valibot": "^1.2.0"
	},
	"prettier": {
		"semi": true,
		"useTabs": true,
		"quoteProps": "consistent",
		"singleQuote": true,
		"trailingComma": "es5",
		"bracketSpacing": true
	}
}
